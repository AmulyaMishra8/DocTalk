# Copy to .env and fill in. Never commit the filled-in file.

# ── Required ──────────────────────────────────────────────────────────────
# Postgres with the pgvector extension. A free Neon project works; append
# ?sslmode=require for Neon. Run `pnpm --filter backend migrate` after setting.
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Generation + reranking. Free tier at https://console.groq.com/keys
GROQ_API_KEY=

# ── Services ──────────────────────────────────────────────────────────────
# Docker compose overrides both to the in-network service names.
REDIS_URL=redis://localhost:6379
# Also serves /embed — embeddings run locally in this container, no key needed.
MARKITDOWN_URL=http://localhost:8000

# ── Auth service ──────────────────────────────────────────────────────────
# Defaults already match the auth service in this repo; in Docker, point the
# JWKS URL at the auth container (http://auth-api:4000/...).
AUTH_JWKS_URL=http://localhost:4000/.well-known/jwks.json
AUTH_ISSUER=auth-service
AUTH_AUDIENCE=auth-clients

# ── Optional ──────────────────────────────────────────────────────────────
# LLM_PROVIDER=groq            # groq (default) | gemini
# GEMINI_API_KEY=              # only when LLM_PROVIDER=gemini
# CHAT_MODEL=openai/gpt-oss-120b
# UTIL_MODEL=openai/gpt-oss-20b
# LLM_MIN_GAP_MS=1500          # minimum gap between generation calls
# PORT=3000
# LOG_LEVEL=info
